{% layout none %}
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ page.title | default: 'Minimal Club B2B — Uniformes Premium para Empresas' }}</title>
  <style>
/* ══ RESET ══ */
.lp-demo *,
.lp-demo *::before,
.lp-demo *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ══ BASE ══ */
.lp-demo {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  color: #1a1a1a;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;

  --bg: #ffffff;
  --ink: #141414;
  --muted: #5b5b5b;
  --muted-2: #777;
  --hairline: rgba(20, 20, 20, 0.1);
  --card: rgba(255, 255, 255, 0.9);
  --shadow: 0 18px 60px rgba(0, 0, 0, 0.08);

  --gold: #c8a96e;
  --gold-2: #b8994e;

  --radius-lg: 22px;
  --radius-md: 16px;

  --container: 1200px;
  --container-mid: 960px;
  --container-narrow: 760px;

  --pad-x: clamp(18px, 4vw, 56px);
  --section-y: clamp(64px, 9vw, 110px);
  --section-y-hero: clamp(72px, 10vw, 128px);

  background: var(--bg);
}

.lp-demo .wrap {
  max-width: var(--container);
  margin: 0 auto;
  padding: 0 var(--pad-x);
}

.lp-demo .wrap--mid {
  max-width: var(--container-mid);
  margin: 0 auto;
  padding: 0 var(--pad-x);
}

.lp-demo .wrap--narrow {
  max-width: var(--container-narrow);
  margin: 0 auto;
  padding: 0 var(--pad-x);
}

/* ══ TYPOGRAPHY ══ */
.lp-demo h1 {
  font-size: clamp(2.05rem, 3.9vw, 3.55rem);
  font-weight: 900;
  line-height: 1.08;
  color: #fff;
  margin-bottom: 24px;
  letter-spacing: -0.02em;
}

.lp-demo h1 em {
  color: #c8a96e;
  font-style: normal;
}

.lp-demo h2 {
  font-size: clamp(1.55rem, 2.6vw, 2.55rem);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: 16px;
  letter-spacing: -0.01em;
}

.lp-demo h3 {
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 8px;
}

.lp-demo .h2-sub {
  font-size: 0.5em;
  color: var(--gold);
  font-weight: 600;
}

.lp-demo p {
  font-size: clamp(1rem, 0.35vw + 0.95rem, 1.08rem);
  color: var(--muted);
  margin-bottom: 16px;
  line-height: 1.7;
}

.lp-demo .label {
  display: block;
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 14px;
}

/* ══ BUTTON ══ */
.lp-demo .btn {
  display: inline-block;
  background: var(--gold);
  color: var(--ink);
  font-size: 0.95rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 20px 52px;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  text-align: center;
  border-radius: 999px;
  box-shadow: 0 10px 26px rgba(200, 169, 110, 0.22);
}

.lp-demo .btn:hover {
  background: var(--gold-2);
  transform: translateY(-2px);
}

.lp-demo .btn:focus-visible {
  outline: 3px solid rgba(200, 169, 110, 0.45);
  outline-offset: 3px;
}

.lp-demo .btn--dark {
  background: #0f0f0f;
  color: #fff;
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.25);
}

.lp-demo .btn--dark:hover {
  background: #333;
}

.lp-demo .btn-note {
  display: block;
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 12px;
  text-align: center;
}

.lp-demo .btn-note--light {
  color: #c8c8c8;
}

/* ══════════════════════
   1 — HERO
══════════════════════ */
.lp-demo .hero {
  background:
    radial-gradient(900px 520px at 50% 0%, rgba(200, 169, 110, 0.16), transparent 60%),
    radial-gradient(700px 460px at 10% 20%, rgba(255, 255, 255, 0.06), transparent 55%),
    #0f0f10;
  padding: var(--section-y-hero) 0 clamp(52px, 7vw, 92px);
  text-align: center;
}

.lp-demo .hero .eyebrow {
  display: inline-block;
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 28px;
  border: 1px solid rgba(255, 255, 255, 0.14);
  padding: 8px 16px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.04);
}

.lp-demo .hero h1 {
  max-width: 940px;
  margin: 0 auto 22px;
}

.lp-demo .hero .sub {
  font-size: clamp(1.06rem, 0.6vw + 1rem, 1.2rem);
  color: rgba(255, 255, 255, 0.68);
  max-width: 680px;
  margin: 0 auto 40px;
}

.lp-demo .hero .sub strong {
  color: #fff;
}

.lp-demo .hero .cta-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.lp-demo .cta-wrap--center {
  text-align: center;
}

.lp-demo .hero .media-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-top: 52px;
  flex-wrap: wrap;
}

.lp-demo .hero .media-bar-label {
  font-size: 0.62rem;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-right: 8px;
}

.lp-demo .hero .media-tag {
  font-size: 0.72rem;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.55);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  border: 1px solid rgba(255, 255, 255, 0.14);
  padding: 7px 14px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.03);
}

/* ══════════════════════
   2 — DOR / STORY
══════════════════════ */
.lp-demo .pain {
  background: #f9f8f6;
  padding: var(--section-y) 0;
}

.lp-demo .pain h2 {
  color: #1a1a1a;
}

.lp-demo .pain .intro {
  font-size: clamp(1.05rem, 0.5vw + 1rem, 1.18rem);
  color: #444;
  margin-bottom: 40px;
}

.lp-demo .pain .pain-callout {
  font-size: 1rem;
  font-weight: 700;
  color: #2a2a2a;
  border-left: 3px solid #c8a96e;
  padding-left: 14px;
  margin-bottom: 28px;
  line-height: 1.55;
}

.lp-demo .pain .pain-sub-intro {
  font-size: 0.95rem;
  color: #555;
  margin-bottom: 14px;
}

.lp-demo .case {
  background: #fff;
  border-left: 4px solid #c8a96e;
  padding: 32px;
  margin-bottom: 36px;
  border-radius: var(--radius-lg);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.08);
}

.lp-demo .case p {
  font-size: 0.96rem;
  color: #444;
  margin-bottom: 10px;
}

.lp-demo .case p:last-of-type {
  margin-bottom: 0;
}

.lp-demo .case-roi {
  display: inline-block;
  margin-top: 14px;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(200, 169, 110, 0.15);
  color: #7a612d;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.lp-demo .bullets {
  list-style: none;
  border: 1px solid #e9e4d9;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: #fff;
  box-shadow: 0 2px 20px rgba(0, 0, 0, 0.04);
}

.lp-demo .bullets li {
  display: grid;
  grid-template-columns: 22px 1fr;
  gap: 14px;
  padding: 16px 18px;
  border-bottom: 1px solid #f1eee7;
  color: #444;
  font-size: 0.95rem;
  line-height: 1.55;
}

.lp-demo .bullets li:last-child {
  border-bottom: none;
}

.lp-demo .bullet-x {
  display: inline-flex;
  width: 22px;
  height: 22px;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(210, 74, 74, 0.08);
  color: #d24a4a;
  font-weight: 900;
  font-size: 0.92rem;
  line-height: 1;
}

/* ══════════════════════
   3 — PROVA SOCIAL
══════════════════════ */
.lp-demo .proof {
  background: #fff;
  padding: var(--section-y) 0;
}

.lp-demo .proof .head {
  text-align: center;
  margin-bottom: 50px;
}

.lp-demo .proof .head h2 {
  max-width: 22ch;
  margin-left: auto;
  margin-right: auto;
  color: #1a1a1a;
}

.lp-demo .stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
  margin-bottom: 48px;
}

.lp-demo .stat {
  background: #111;
  border-radius: 20px;
  padding: 40px 32px;
  text-align: center;
  border: 1px solid #222;
  box-shadow: 0 16px 50px rgba(0, 0, 0, 0.22);
}

.lp-demo .stat-num {
  display: block;
  font-size: 3rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  margin-bottom: 10px;
  letter-spacing: -0.02em;
}

.lp-demo .stat-lbl {
  display: block;
  font-size: 0.78rem;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: #8d8d8d;
  font-weight: 700;
}

.lp-demo .logos {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 60px;
}

.lp-demo .logo-item {
  position: relative;
}

.lp-demo .logo-item::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 999px;
  box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
  opacity: 0;
  transition: opacity 0.2s ease;
  pointer-events: none;
}

.lp-demo .logo-item:hover::after {
  opacity: 1;
}

.lp-demo .logo-item {
  border: 1px solid #eee;
  border-radius: 999px;
  padding: 12px 10px;
  text-align: center;
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #444;
  background: #fafafa;
}

.lp-demo .testimonials {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
  margin-bottom: 40px;
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
}

.lp-demo .tcard {
  border: 1px solid #eee;
  background: #fff;
  border-radius: 18px;
  padding: 26px 22px;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  position: relative;
}

.lp-demo .tcard:hover {
  transform: translateY(-2px);
  transition: transform 0.15s ease, box-shadow 0.2s ease;
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.08);
}

.lp-demo .tcard::before {
  content: "\201C";
  position: absolute;
  top: 10px;
  left: 16px;
  font-size: 3.2rem;
  line-height: 1;
  color: rgba(200, 169, 110, 0.35);
  font-weight: 900;
}

.lp-demo .tcard-headline {
  display: block;
  font-size: 0.92rem;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 4px;
}

.lp-demo .tcard-text {
  margin-top: 12px;
  color: #444;
  font-size: 0.95rem;
}

.lp-demo .tcard-result {
  display: inline-flex;
  margin-top: 16px;
  padding: 7px 12px;
  border-radius: 999px;
  background: rgba(26, 26, 26, 0.06);
  color: #1a1a1a;
  font-weight: 800;
  font-size: 0.78rem;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.lp-demo .tcard-author {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 12px;
  margin-top: 18px;
  align-items: center;
}

.lp-demo .tcard-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: linear-gradient(135deg, #eee, #ddd);
  border: 1px solid #eee;
}

.lp-demo .tcard-name {
  display: block;
  font-weight: 900;
  color: #1a1a1a;
  font-size: 0.92rem;
}

.lp-demo .tcard-role {
  display: block;
  color: #777;
  font-size: 0.82rem;
  margin-top: 2px;
}

/* ══════════════════════
   4 — STACK DE VALOR
══════════════════════ */
.lp-demo .value {
  background: #111;
  color: #fff;
  padding: var(--section-y) 0;
}

.lp-demo .value .head {
  text-align: center;
  margin-bottom: 50px;
}

.lp-demo .value .head h2 {
  max-width: 20ch;
  margin-left: auto;
  margin-right: auto;
  color: #fff;
}

.lp-demo .value .head p {
  color: #bdbdbd;
}

.lp-demo .value-list {
  list-style: none;
  display: grid;
  gap: 14px;
  max-width: 920px;
  margin: 0 auto 36px;
}

.lp-demo .vitem {
  display: grid;
  grid-template-columns: 56px 1fr;
  gap: 16px;
  align-items: start;
  background: #151515;
  border: 1px solid #222;
  border-radius: 16px;
  padding: 18px 18px;
}

.lp-demo .vitem:hover {
  border-color: rgba(200, 169, 110, 0.35);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.22);
}

.lp-demo .vnum {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background: rgba(200, 169, 110, 0.18);
  color: #c8a96e;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}

.lp-demo .vcontent p {
  color: #b9b9b9;
  margin-bottom: 0;
}

.lp-demo .vcontent h3 {
  color: #fff;
  margin-bottom: 6px;
}

.lp-demo .vprice {
  font-size: 0.82rem;
  font-weight: 900;
  color: #c8a96e;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding-top: 8px;
  white-space: nowrap;
}

.lp-demo .vtotal {
  max-width: 920px;
  margin: 0 auto 30px;
  border: 1px solid #2a2a2a;
  border-radius: 16px;
  padding: 18px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  flex-wrap: wrap;
}

.lp-demo .vtotal-label {
  color: #bdbdbd;
  font-weight: 800;
}

.lp-demo .vtotal-was {
  color: #888;
  text-decoration: line-through;
  font-weight: 900;
  font-size: 0.95rem;
  text-align: right;
}

.lp-demo .vtotal-free {
  color: #c8a96e;
  font-weight: 900;
  font-size: 1.4rem;
  text-align: right;
}

/* ══════════════════════
   5 — GARANTIA
══════════════════════ */
.lp-demo .guarantee {
  background: #f9f8f6;
  padding: var(--section-y) 0;
}

.lp-demo .gbox {
  background: #fff;
  border: 1px solid #eee;
  border-radius: 22px;
  padding: 56px 46px;
  max-width: 920px;
  margin: 0 auto 22px;
  text-align: center;
  box-shadow: 0 2px 18px rgba(0, 0, 0, 0.04);
}

.lp-demo .gbadge {
  display: inline-block;
  background: rgba(200, 169, 110, 0.15);
  border: 1px solid rgba(200, 169, 110, 0.25);
  color: #7a612d;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-size: 0.7rem;
  padding: 8px 14px;
  border-radius: 999px;
  margin-bottom: 18px;
}

.lp-demo .gintro {
  color: #666;
  margin-bottom: 6px;
}

.lp-demo .gamount {
  font-size: 4rem;
  font-weight: 900;
  color: #1a1a1a;
  line-height: 1;
  margin: 6px 0;
}

.lp-demo .gtitle {
  font-size: 1.2rem;
  font-weight: 900;
  color: #1a1a1a;
  margin-bottom: 14px;
}

.lp-demo .gdesc {
  color: #666;
  font-size: 0.96rem;
  max-width: 660px;
  margin: 0 auto;
}

.lp-demo .gbox-right .btn {
  margin-top: 8px;
}

.lp-demo .gfine {
  text-align: center;
  color: #777;
  font-size: 0.88rem;
  margin-bottom: 0;
}

/* ══════════════════════
   6 — FAQ
══════════════════════ */
.lp-demo .faq {
  background: #fff;
  padding: var(--section-y) 0;
}

.lp-demo .faq .head {
  text-align: center;
  margin-bottom: 36px;
}

.lp-demo .faq-list {
  max-width: 920px;
  margin: 0 auto;
  display: grid;
  gap: 12px;
}

.lp-demo .faq-item {
  border: 1px solid #eee;
  border-radius: 16px;
  overflow: hidden;
  background: #fff;
}

.lp-demo .faq-item:hover {
  border-color: rgba(20, 20, 20, 0.14);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.06);
}

.lp-demo .faq-q {
  width: 100%;
  text-align: left;
  border: none;
  background: #fff;
  cursor: pointer;
  padding: 18px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  font-weight: 900;
  color: #1a1a1a;
  font-size: 0.98rem;
}

.lp-demo .faq-q:focus-visible {
  outline: 3px solid rgba(200, 169, 110, 0.35);
  outline-offset: 3px;
  border-radius: 10px;
}

.lp-demo .faq-icon {
  font-size: 1.1rem;
  color: #c8a96e;
  font-weight: 900;
}

.lp-demo .faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.25s ease;
  border-top: 1px solid #f3f3f3;
}

.lp-demo .faq-a-inner {
  padding: 16px 18px 18px;
  color: #555;
  font-size: 0.95rem;
  line-height: 1.65;
}

.lp-demo .faq-item.open .faq-a {
  max-height: 520px;
}

.lp-demo .faq-item.open .faq-icon {
  transform: rotate(45deg);
  display: inline-block;
  transition: transform 0.2s ease;
}

/* ══════════════════════
   7 — FORM
══════════════════════ */
.lp-demo .form-sec {
  background: #111;
  padding: var(--section-y) 0;
}

.lp-demo .form-sec .head {
  text-align: center;
  margin-bottom: 36px;
}

.lp-demo .form-sec .head h2 {
  max-width: 22ch;
  margin-left: auto;
  margin-right: auto;
  color: #fff;
}

.lp-demo .form-sec .head p {
  color: #bdbdbd;
}

.lp-demo .form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
  align-items: start;
}

.lp-demo .finfo {
  border: 1px solid #222;
  border-radius: 18px;
  padding: 28px 26px;
  background: #151515;
}

.lp-demo .finfo h3 {
  color: #fff;
}

.lp-demo .finfo ul {
  margin-top: 12px;
  padding-left: 18px;
  color: #bdbdbd;
}

.lp-demo .finfo li {
  margin-bottom: 10px;
}

.lp-demo .gmini {
  margin-top: 18px;
  border-radius: 16px;
  padding: 14px 14px;
  background: rgba(200, 169, 110, 0.1);
  border: 1px solid rgba(200, 169, 110, 0.18);
  color: #d4c09a;
  font-size: 0.92rem;
  line-height: 1.5;
}

.lp-demo .fcard {
  background: #fff;
  border-radius: 18px;
  padding: 34px 28px;
  border: 1px solid #eee;
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.08);
}

.lp-demo .fnote {
  display: block;
  text-align: center;
  margin-top: 14px;
  color: #777;
  font-size: 0.86rem;
  font-weight: 700;
}

.lp-demo .ftrust {
  margin-top: 16px;
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

.lp-demo .ftrust-item {
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #666;
  border: 1px solid #eee;
  background: #fafafa;
  padding: 7px 10px;
  border-radius: 999px;
}

/* ══════════════════════
   8 — URGÊNCIA / CTA / FOOTER
══════════════════════ */
.lp-demo .urgency {
  background: #f9f8f6;
  padding: 24px 0;
  text-align: center;
}

.lp-demo .urgency p {
  margin-bottom: 0;
  color: #444;
}

.lp-demo .ctaband {
  background: #f9f8f6;
  padding: var(--section-y) 0;
}

.lp-demo .ctaband .wrap--narrow {
  text-align: center;
}

.lp-demo .lp-footer {
  background: #111;
